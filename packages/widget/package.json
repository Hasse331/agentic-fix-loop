{
  "name": "@hansimb/fix-loop-widget",
  "version": "0.1.2",
  "type": "module",
  "description": "Reusable React widget for collecting anonymous problem reports into Supabase.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hansimb/agentic-fix-loop.git",
    "directory": "packages/widget"
  },
  "bugs": {
    "url": "https://github.com/hansimb/agentic-fix-loop/issues"
  },
  "homepage": "https://github.com/hansimb/agentic-fix-loop#readme",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "bug-reporting",
    "feedback-widget",
    "react",
    "supabase"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --experimental-strip-types tests/run-tests.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.1",
    "react": "^19.0.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.2"
  }
}
